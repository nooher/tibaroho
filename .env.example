# Tumaini · TBHOS — environment template
#
# Tumaini shares the THOS Supabase project (Laetoli (T) Ltd Pro tier) until
# Laetoli Data (sovereign self-hosted, Tanzania) is live. Tables are namespaced
# `tr_*` so they never collide with THOS tables. Both products share auth.users.
#
# To run locally: copy this file to .env and fill in the values.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-jwt>
